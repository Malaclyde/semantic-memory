{
  "name": "semantic-memory",
  "version": "0.1.0",
  "description": "Persistent memory backend for AI agents with vector search, FTS5, reranker, and EAV metadata",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./kb/embedder": "./src/kb/embedder.ts",
    "./kb/reranker": "./src/kb/reranker.ts",
    "./kb/db": "./src/kb/db.ts",
    "./kb/dbo": "./src/kb/dbo.ts"
  },
  "files": [
    "src/",
    "opencode/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "better-sqlite3": "^12.9.0",
    "sqlite-vec": "^0.1.9"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^7.x"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "seed": "npx tsx src/seed.ts",
    "viewer": "npx tsx viewer/viewer.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "memory",
    "rag",
    "vector-search",
    "fts5",
    "ai-agents",
    "opencode"
  ],
  "license": "MIT"
}
