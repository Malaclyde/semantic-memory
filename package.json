{
  "name": "@malaclyde/knowledge-base",
  "version": "0.0.2",
  "description": "Persistent memory backend for AI agents with vector search, FTS5, reranker, and EAV metadata",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./kb/embedder": "./src/kb/embedder.ts",
    "./kb/reranker": "./src/kb/reranker.ts",
    "./kb/db": "./src/kb/db.ts",
    "./kb/dbo": "./src/kb/dbo.ts",
    "./kb/wrappers/coding": "./src/kb/wrappers/coding.ts",
    "./kb/wrappers/assistant": "./src/kb/wrappers/assistant.ts",
    "./kb/wrappers/base": "./src/kb/wrappers/base.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Malaclyde/semantic-memory.git"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    ".",
    "opencode/coding-memory",
    "opencode/assistant-memory"
  ],
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "better-sqlite3": "^12.9.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "seed": "npx tsx src/seed.ts",
    "viewer": "npx tsx viewer/viewer.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "memory",
    "rag",
    "vector-search",
    "fts5",
    "ai-agents",
    "opencode"
  ],
  "license": "MIT"
}
